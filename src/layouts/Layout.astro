---
import { Main } from "@/routes/Main";
import { formatPath } from "@/libs/format-path";
import { formatTitle } from "@/libs/format-title";
import { getTitle } from "@/libs/title";

const path = formatPath(Astro.url.pathname);
const pageTitle = formatTitle(getTitle("/" + path));

interface Props {
	notFound?: boolean;
}
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="彩季のポートフォリオです。" />
		<meta name="format-detection" content="email=no,telephone=no,address=no" />
		<meta name="author" content="彩季" />
		<!-- Google Tag Manager -->
		<script is:inline>
			// prettier-ignore
			(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
			new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
			j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
			'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
			})(window,document,'script','dataLayer','GTM-KGV4LZWH');
		</script>
		<!-- End Google Tag Manager -->
		<link rel="canonical" href={`https://aki.wtf/${path}`} />
		<link rel="icon" href="/favicon.ico" />
		<title>{pageTitle}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Concert+One&display=swap&text=Aki404" rel="stylesheet" />
		<link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@500&display=swap" rel="stylesheet" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<script async src="//cdn.iframe.ly/embed.js" charset="utf-8"></script>
	</head>
	<body>
		<!-- Google Tag Manager (noscript) -->
		<noscript>
			<iframe
				src="https://www.googletagmanager.com/ns.html?id=GTM-KGV4LZWH"
				height="0"
				width="0"
				style="display:none;visibility:hidden"></iframe>
		</noscript>
		<!-- End Google Tag Manager (noscript) -->
		<Main client:only />
	</body>
</html>

<style is:global lang="scss">
	* {
		box-sizing: border-box;
		padding: 0;
		margin: 0;
		font-family: "Zen Maru Gothic", "游ゴシック体", YuGothic, "游ゴシック", "メイリオ", Meiryo,
			"Hiragino Kaku Gothic Pro", "ヒラギノ角ゴ Pro W3", "ＭＳ Ｐゴシック", sans-serif;
		font-size: 18px;
		line-height: 1.8;
		font-weight: 400;
		color: white;

		&:focus {
			outline: none;
		}
	}

	html,
	body {
		width: 100%;
		height: 100%;
	}

	html {
		overflow: hidden;
	}

	body {
		background-color: #fc9e81;
		overflow-y: scroll;

		@media (prefers-color-scheme: dark) {
			background-color: #283927;
		}
	}

	img {
		max-width: 100%;
		height: auto;
	}
</style>
